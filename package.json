{
  "name": "aria-kernel-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace for @interactive-os/aria-kernel only.",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @interactive-os/aria-kernel build",
    "test": "pnpm --filter @interactive-os/aria-kernel test",
    "typecheck": "pnpm --filter @interactive-os/aria-kernel typecheck",
    "typedoc": "pnpm --filter @interactive-os/aria-kernel typedoc",
    "clean": "pnpm --filter @interactive-os/aria-kernel clean",
    "guard:chords": "node scripts/guardChordRegistry.mjs",
    "audit:axis": "node scripts/auditAxisCompleteness.mjs",
    "refactor:intent-folders": "node scripts/refactor-intent-kernel-folders.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
