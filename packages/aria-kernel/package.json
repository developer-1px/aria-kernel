{
  "name": "@p/aria-kernel",
  "version": "0.0.13",
  "description": "React + Reducer 기반 accessible intent 행동 인프라 — W3C/APG 패턴 recipe + axis 합성 + roving tabindex + gesture/intent 변환. 데이터는 use<Pattern>Reducer(items, opts?) 1줄. 토큰/CSS/UI 어휘 0건.",
  "keywords": [
    "aria",
    "wai-aria",
    "apg",
    "accessibility",
    "a11y",
    "react",
    "headless",
    "reducer",
    "useReducer",
    "roving-tabindex",
    "behavior-infrastructure"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developer-1px/aria-kernel.git",
    "directory": "packages/aria-kernel"
  },
  "homepage": "https://github.com/developer-1px/aria-kernel#readme",
  "bugs": "https://github.com/developer-1px/aria-kernel/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./patterns": {
      "development": "./src/patterns/index.ts",
      "types": "./dist/patterns/index.d.ts",
      "import": "./dist/patterns/index.js",
      "require": "./dist/patterns/index.cjs"
    },
    "./axes": {
      "development": "./src/axes/index.ts",
      "types": "./dist/axes/index.d.ts",
      "import": "./dist/axes/index.js",
      "require": "./dist/axes/index.cjs"
    },
    "./gesture": {
      "development": "./src/gesture/index.ts",
      "types": "./dist/gesture/index.d.ts",
      "import": "./dist/gesture/index.js",
      "require": "./dist/gesture/index.cjs"
    },
    "./key": {
      "development": "./src/key/index.ts",
      "types": "./dist/key/index.d.ts",
      "import": "./dist/key/index.js",
      "require": "./dist/key/index.cjs"
    },
    "./roving": {
      "development": "./src/roving/index.ts",
      "types": "./dist/roving/index.d.ts",
      "import": "./dist/roving/index.js",
      "require": "./dist/roving/index.cjs"
    },
    "./state": {
      "development": "./src/state/index.ts",
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js",
      "require": "./dist/state/index.cjs"
    },
    "./focus": {
      "development": "./src/focus/index.ts",
      "types": "./dist/focus/index.d.ts",
      "import": "./dist/focus/index.js",
      "require": "./dist/focus/index.cjs"
    },
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    },
    "./*/": {
      "development": "./src/*/index.ts",
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs"
    },
    "./read/*": {
      "development": "./src/read/*/index.ts",
      "types": "./dist/read/*/index.d.ts",
      "import": "./dist/read/*/index.js",
      "require": "./dist/read/*/index.cjs"
    },
    "./read/*/*": {
      "development": "./src/read/*/*.ts",
      "types": "./dist/read/*/*.d.ts",
      "import": "./dist/read/*/*.js",
      "require": "./dist/read/*/*.cjs"
    },
    "./input/*": {
      "development": "./src/input/*/index.ts",
      "types": "./dist/input/*/index.d.ts",
      "import": "./dist/input/*/index.js",
      "require": "./dist/input/*/index.cjs"
    },
    "./input/*/*": {
      "development": "./src/input/*/*.ts",
      "types": "./dist/input/*/*.d.ts",
      "import": "./dist/input/*/*.js",
      "require": "./dist/input/*/*.cjs"
    },
    "./input/keyboard/*": {
      "development": "./src/input/keyboard/*/index.ts",
      "types": "./dist/input/keyboard/*/index.d.ts",
      "import": "./dist/input/keyboard/*/index.js",
      "require": "./dist/input/keyboard/*/index.cjs"
    },
    "./input/keyboard/*/*": {
      "development": "./src/input/keyboard/*/*.ts",
      "types": "./dist/input/keyboard/*/*.d.ts",
      "import": "./dist/input/keyboard/*/*.js",
      "require": "./dist/input/keyboard/*/*.cjs"
    },
    "./intent/*": {
      "development": "./src/intent/*.ts",
      "types": "./dist/intent/*.d.ts",
      "import": "./dist/intent/*.js",
      "require": "./dist/intent/*.cjs"
    },
    "./view-state": {
      "development": "./src/view-state/index.ts",
      "types": "./dist/view-state/index.d.ts",
      "import": "./dist/view-state/index.js",
      "require": "./dist/view-state/index.cjs"
    },
    "./view-state/*": {
      "development": "./src/view-state/*.ts",
      "types": "./dist/view-state/*.d.ts",
      "import": "./dist/view-state/*.js",
      "require": "./dist/view-state/*.cjs"
    }
  },
  "files": [
    "dist",
    "INVARIANTS.md",
    "PATTERNS.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc --watch",
    "clean": "rm -rf dist docs/api"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
